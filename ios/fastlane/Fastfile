require "fileutils"
require "spaceship"

# ── Spaceship patches for fastlane 2.230's stale ASC endpoints ────────────────
# fastlane 2.230 serializes `publicLinkEnabled` / `publicLinkLimit` /
# `publicLinkLimitEnabled` in POST /v1/betaGroups even for INTERNAL groups,
# which ASC rejects ("Public link limit cannot be applied to internal group").
# It also POSTs to the removed /v1/bulkBetaTesterAssignments endpoint. These
# patches route through the endpoints Apple still supports. Drop once we bump
# to a fastlane where these are fixed upstream.
if defined?(::Spaceship::ConnectAPI::Models::BetaGroup)
  ::Spaceship::ConnectAPI::Models::BetaGroup.class_eval do
    def post_bulk_beta_tester_assignments(client: nil, beta_testers: nil)
      client ||= ::Spaceship::ConnectAPI
      (beta_testers || []).each do |tester|
        existing = client.get_beta_testers(filter: { email: tester[:email] })
                         .flat_map(&:to_models).first
        if existing
          client.add_beta_tester_to_group(beta_group_id: id, beta_tester_ids: [existing.id])
        else
          client.post_beta_tester_assignment(beta_group_ids: [id], attributes: tester)
        end
      end
    end
  end
end

::Spaceship::ConnectAPI::TestFlight::API.module_eval do
  define_method(:create_beta_group) do |app_id: nil, group_name: nil, is_internal_group: false, public_link_enabled: false, public_link_limit: 10_000, public_link_limit_enabled: false, has_access_to_all_builds: nil|
    if is_internal_group
      has_access_to_all_builds = true if has_access_to_all_builds.nil?
    else
      has_access_to_all_builds = nil
    end
    attributes = {
      name: group_name,
      isInternalGroup: is_internal_group,
      hasAccessToAllBuilds: has_access_to_all_builds
    }
    unless is_internal_group
      attributes[:publicLinkEnabled]      = public_link_enabled
      attributes[:publicLinkLimit]        = public_link_limit
      attributes[:publicLinkLimitEnabled] = public_link_limit_enabled
    end
    body = {
      data: {
        attributes: attributes,
        relationships: { app: { data: { id: app_id, type: "apps" } } },
        type: "betaGroups"
      }
    }
    test_flight_request_client.post("v1/betaGroups", body)
  end
end

default_platform(:ios)

APP_IDENTIFIER = "me.pai.pharos.mobile"
XCODEPROJ      = "PharosMobile.xcodeproj"
TARGET         = "PharosMobile"
TEAM_ID        = "TN7ZDD72P2"

# ── Credential helpers ────────────────────────────────────────────────────────

# Every action that takes an in-memory `api_key:` hash ALSO auto-fills
# `api_key_path:` from APP_STORE_CONNECT_API_KEY_PATH, then bails with
# "Unresolved conflict between options". Build the hash first, then run the
# rest of the lane with the env var cleared.
def with_env_unset(*keys)
  saved = keys.each_with_object({}) { |k, h| h[k] = ENV.delete(k) }
  yield
ensure
  saved.each { |k, v| ENV[k] = v if v }
end

def load_env_file
  env_path = File.expand_path("../.env", __dir__)
  return unless File.exist?(env_path)

  File.readlines(env_path).each do |line|
    stripped = line.strip
    next if stripped.empty? || stripped.start_with?("#")

    key, _sep, value = stripped.partition("=")
    next if key.empty?

    ENV[key] = value if ENV[key].to_s.strip.empty?
  end
end

# Version truth is project.yml's MARKETING_VERSION — the generated Info.plist
# only references it via $(), so get_version_number can return the placeholder.
def marketing_version
  yml = File.read(File.expand_path("../project.yml", __dir__))
  yml[/MARKETING_VERSION:\s*"([^"]+)"/, 1] ||
    UI.user_error!("MARKETING_VERSION not found in project.yml")
end

def asc_api_key
  load_env_file

  missing = %w[
    APP_STORE_CONNECT_API_KEY_ID
    APP_STORE_CONNECT_API_ISSUER_ID
    APP_STORE_CONNECT_API_KEY_PATH
  ].select { |k| ENV[k].to_s.strip.empty? }

  UI.user_error!("Missing env vars: #{missing.join(', ')}") unless missing.empty?

  app_store_connect_api_key(
    key_id:       ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id:    ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
    key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
    in_house:     false
  )
end

# Some ASC endpoints below have no api_key-aware fastlane action (pricing,
# age rating, build attach, reviewSubmissions) — drive Spaceship directly.
def with_spaceship(api_key)
  require "spaceship"
  token = ::Spaceship::ConnectAPI::Token.create(
    key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
  )
  ::Spaceship::ConnectAPI.token = token
  yield ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
end

# ── Platform ──────────────────────────────────────────────────────────────────

platform :ios do
  before_all do
    # Temp keychain on CI — and on demand: macOS 26 scopes keychain unlock to
    # the security session, so an agent shell can hit errSecInternalComponent
    # even after the key was interactively approved. PHAROS_TEMP_KEYCHAIN=1
    # gives match a keychain it owns (it can set the partition list there).
    # Caller must restore the keychain search list afterwards on a dev machine.
    setup_ci(force: true) if is_ci || ENV["PHAROS_TEMP_KEYCHAIN"] == "1"
    sh "cd .. && xcodegen generate" if File.exist?("../project.yml")
  end

  # ── One-time Apple Developer Portal bootstrap ────────────────────────────────

  desc "Register the App ID in the Developer Portal and sync match profiles. " \
       "Idempotent — re-run after editing entitlements. Only needed for the " \
       "TestFlight/App Store path; `device_install` uses automatic signing and " \
       "does not require this."
  lane :bootstrap do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      produce(
        api_key:        api_key,
        app_identifier: APP_IDENTIFIER,
        app_name:       "Pharos",
        skip_itc:       true               # ASC record created by create_asc_app
      )
      match(
        type:                    "development",
        api_key:                 api_key,
        app_identifier:          [APP_IDENTIFIER],
        force_for_new_devices:   true,
        force_legacy_encryption: true,
        readonly:                false
      )
      match(
        type:                    "appstore",
        api_key:                 api_key,
        app_identifier:          [APP_IDENTIFIER],
        force_legacy_encryption: true,
        readonly:                false
      )
    end
    UI.success("Bootstrap complete.")
  end

  # ── Code signing ─────────────────────────────────────────────────────────────

  desc "Enable the iCloud capability on the App ID (the app entitles " \
       "ubiquity-kvstore for multi-machine sync) and force-regenerate the " \
       "appstore match profile so it embeds the entitlement. Idempotent."
  lane :fix_icloud_capability do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |_app|
        client = ::Spaceship::ConnectAPI.tunes_request_client
        bid = client.get("v1/bundleIds", { "filter[identifier]" => APP_IDENTIFIER })
                    .body["data"].find { |b| b["attributes"]["identifier"] == APP_IDENTIFIER }
        UI.user_error!("Bundle ID #{APP_IDENTIFIER} not registered in the portal") unless bid
        caps = client.get("v1/bundleIds/#{bid['id']}/bundleIdCapabilities").body["data"]
        UI.message("capabilities: #{caps.map { |c| c['attributes']['capabilityType'] }.inspect}")
        if caps.any? { |c| c["attributes"]["capabilityType"] == "ICLOUD" }
          UI.success("ICLOUD already enabled")
        else
          client.post("v1/bundleIdCapabilities", {
            data: {
              type: "bundleIdCapabilities",
              attributes: {
                capabilityType: "ICLOUD",
                settings: [{ key: "ICLOUD_VERSION", options: [{ key: "XCODE_6" }] }]
              },
              relationships: { bundleId: { data: { type: "bundleIds", id: bid["id"] } } }
            }
          })
          UI.success("ICLOUD capability enabled on #{APP_IDENTIFIER}")
        end
      end
      match(
        type:                    "appstore",
        api_key:                 api_key,
        app_identifier:          [APP_IDENTIFIER],
        force:                   true,        # regenerate so the profile embeds iCloud
        force_legacy_encryption: true,
        readonly:                false
      )
    end
  end

  desc "Sync App Store certificates & provisioning profiles via match"
  lane :certs do
    match(
      type:                    "appstore",
      api_key:                 asc_api_key,
      force_legacy_encryption: true,
      readonly:                is_ci
    )
  end

  # ── Build helpers ─────────────────────────────────────────────────────────────

  desc "Bump build number to the current git commit count"
  lane :bump_build do
    build_number = sh("git rev-list --count HEAD").strip
    increment_build_number(build_number: build_number, xcodeproj: XCODEPROJ)
  end

  # ── Device install (devicectl) ────────────────────────────────────────────────

  desc "Build a development-signed .ipa and install it onto a paired iPhone/iPad " \
       "via Xcode's devicectl. Pass `udid:` to target a specific device; defaults " \
       "to the first paired iOS device. Uses automatic signing (project.yml sets " \
       "CODE_SIGN_STYLE=Automatic) — no match needed, just sign into Xcode → " \
       "Settings → Accounts once and enable Developer Mode on the device."
  lane :device_install do |options|
    udid = options[:udid] || ENV["DEVICE_UDID"] || first_paired_device_udid
    UI.user_error!("No paired iOS device found. Connect one, trust this Mac, enable Developer Mode, then retry.") if udid.to_s.empty?

    build_app(
      scheme:           TARGET,
      configuration:    "Debug",
      export_method:    "development",
      include_bitcode:  false,
      skip_package_pkg: true,
      output_directory: "build/device",
      output_name:      "#{TARGET}.ipa",
      xcargs:           "-skipPackagePluginValidation -skipMacroValidation -allowProvisioningUpdates",
      export_options:   { signingStyle: "automatic", teamID: TEAM_ID }
    )

    ipa = File.expand_path("../build/device/#{TARGET}.ipa", __dir__)
    UI.user_error!("Build produced no .ipa at #{ipa}") unless File.exist?(ipa)

    UI.message("Installing #{ipa} → device #{udid}")
    sh "xcrun devicectl device install app --device #{udid} #{ipa.shellescape}"
    UI.success("Installed. Launch from the home screen, or: " \
               "xcrun devicectl device process launch --device #{udid} #{APP_IDENTIFIER}")
  end

  def first_paired_device_udid
    require "json"
    raw = `xcrun devicectl list devices --json-output - 2>/dev/null`
    return nil if raw.strip.empty?
    parsed = JSON.parse(raw) rescue nil
    return nil unless parsed
    devices = parsed.dig("result", "devices") || []
    paired = devices.find do |d|
      (d.dig("connectionProperties", "pairingState").to_s == "paired") &&
        (d.dig("deviceProperties", "platformIdentifier").to_s.include?("iOS") ||
         d.dig("hardwareProperties", "platform").to_s.include?("iOS"))
    end
    paired&.dig("hardwareProperties", "udid") || paired&.dig("identifier")
  end

  # ── TestFlight ────────────────────────────────────────────────────────────────

  desc "Build Release and upload to TestFlight (internal testing needs no review)."
  lane :beta do
    api_key = asc_api_key                        # build the hash BEFORE unsetting
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      match(
        type:                    "appstore",
        api_key:                 api_key,
        readonly:                is_ci,
        force_legacy_encryption: true             # LibreSSL/fastlane-sirp workaround
      )
      bump_build
      # Archive signing is Manual per-config in project.yml (app target only —
      # SwiftPM package targets reject provisioning profiles, so the specifier
      # can't ride global xcargs).
      build_app(
        scheme:           TARGET,
        configuration:    "Release",
        export_method:    "app-store",
        include_bitcode:  false,
        skip_package_pkg: true,
        xcargs:           "-skipPackagePluginValidation -skipMacroValidation",
        export_options:   {
          signingStyle: "manual",
          teamID:       TEAM_ID,
          provisioningProfiles: { APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}" }
        }
      )
      upload_to_testflight(
        api_key:                           api_key,
        skip_waiting_for_build_processing: true
      )
    end
  end

  # ── App Store Connect record + TestFlight tester management ──────────────────

  desc "Create the App Store Connect record (one-time). Needed before the first " \
       "TestFlight upload if the app doesn't yet exist in ASC."
  lane :create_asc_app do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      produce(
        api_key:        api_key,
        app_identifier: APP_IDENTIFIER,
        app_name:       "Pharos",
        language:       "en-US",
        app_version:    "1.0",
        sku:            "pharos-mobile-ios-001",
        skip_itc:       false,
        skip_devcenter: true,
        team_id:        TEAM_ID
      )
    end
  end

  desc "Read-only: confirm the ASC record exists; print its name and versions."
  lane :verify_asc_app do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      app = ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      UI.user_error!("No ASC record for #{APP_IDENTIFIER} — create it in the ASC web UI first") unless app
      UI.message("ASC app: id=#{app.id} name=#{app.name.inspect}")
      edit = app.get_edit_app_store_version
      live = app.get_live_app_store_version
      UI.message("  edit version: #{edit&.version_string.inspect} state=#{edit&.app_store_state}")
      UI.message("  live version: #{live&.version_string.inspect}")
    end
  end

  desc "Read-only: audit the edit version's staged listing (metadata fields + screenshot counts)."
  lane :audit_listing do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      app = ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      version = app.get_edit_app_store_version
      UI.user_error!("No edit version") unless version
      UI.message("Edit version #{version.version_string} (#{version.app_store_state}) copyright=#{version.copyright.inspect}")
      version.get_app_store_version_localizations.each do |loc|
        UI.message("[#{loc.locale}]")
        UI.message("  description: #{loc.description.to_s.length} chars")
        UI.message("  keywords:    #{loc.keywords.inspect}")
        UI.message("  promo:       #{loc.promotional_text.to_s.length} chars")
        UI.message("  notes:       #{loc.whats_new.inspect}")
        UI.message("  support/marketing: #{loc.support_url.inspect} / #{loc.marketing_url.inspect}")
        loc.get_app_screenshot_sets.each do |set|
          UI.message("  screenshots #{set.screenshot_display_type}: #{set.app_screenshots.size}")
        end
      end
      info = app.fetch_edit_app_info
      if info
        loc = info.get_app_info_localizations.find { |l| l.locale == "en-US" }
        UI.message("appInfo: name=#{loc&.name.inspect} subtitle=#{loc&.subtitle.inspect} privacy_url=#{loc&.privacy_policy_url.inspect}")
      end
    end
  end

  desc "Purge every screenshot from the edit version's sets and re-upload the " \
       "local en-US set exactly once. Works around deliver's verify-loop race " \
       "against ASC's eventual consistency, which duplicates uploads."
  lane :reset_screenshots do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      app = ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      version = app.get_edit_app_store_version
      loc = version.get_app_store_version_localizations.find { |l| l.locale == "en-US" }
      dir = File.expand_path("screenshots/en-US", __dir__)
      loc.get_app_screenshot_sets.each do |set|
        set.app_screenshots.each(&:delete!)
        pattern = set.screenshot_display_type.include?("IPAD") ? "*-ipad-*.png" : "*-iphone-*.png"
        Dir[File.join(dir, pattern)].sort.each do |path|
          UI.message("Uploading #{File.basename(path)} → #{set.screenshot_display_type}")
          ::Spaceship::ConnectAPI::AppScreenshot.create(
            app_screenshot_set_id: set.id, path: path, wait_for_processing: true
          )
        end
      end
      loc.get_app_screenshot_sets.each do |set|
        UI.success("#{set.screenshot_display_type}: #{set.app_screenshots.size} screenshots")
      end
    end
  end

  desc "List ASC team members. Internal TestFlight testers MUST be ASC team members."
  lane :list_asc_users do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      users = ::Spaceship::ConnectAPI.get_users.all_pages.flat_map(&:to_models)
      UI.message("ASC tenant has #{users.size} team member(s):")
      users.each { |u| UI.message("  • id=#{u.id} email=#{u.username} roles=#{u.roles.inspect}") }
    end
  end

  desc "Create a TestFlight Internal Testing group (idempotent). `name:` default 'Internal'."
  lane :ensure_beta_group do |options|
    name = options[:name] || "Internal"
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      app = ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      UI.user_error!("App not found in ASC — run create_asc_app first") unless app
      group = app.get_beta_groups.find { |g| g.name == name } ||
              app.create_beta_group(group_name: name, is_internal_group: true,
                                    has_access_to_all_builds: true)
      UI.success("Group ready: #{group.name} (internal=#{group.is_internal_group})")
    end
  end

  desc "Create + assign a TestFlight tester to a group in one call. " \
       "Usage: fastlane invite_to_group email:you@example.com group:Internal"
  lane :invite_to_group do |options|
    email = options[:email] or UI.user_error!("Pass email:<address>")
    name  = options[:group] || "Internal"
    first = options[:first_name] || email.split("@").first
    last  = options[:last_name]  || "Tester"
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      token = ::Spaceship::ConnectAPI::Token.create(
        key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key]
      )
      ::Spaceship::ConnectAPI.token = token
      app = ::Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
      UI.user_error!("App not found in ASC") unless app
      group = app.get_beta_groups.find { |g| g.name == name }
      UI.user_error!("Group '#{name}' not found — run ensure_beta_group name:#{name}") unless group
      ::Spaceship::ConnectAPI.post_beta_tester_assignment(
        beta_group_ids: [group.id],
        attributes: { email: email, firstName: first, lastName: last }
      )
      UI.success("Invited #{email} to '#{name}' (#{group.id})")
    end
  end

  # ── First-submission version prep (ported from World Monitor's verified run) ─

  desc "Set the app's price to Free (one-time). The FREE price point id must be " \
       "looked up dynamically — the old USA_F sentinel is dead."
  lane :set_price_free do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        pp_resp = ::Spaceship::ConnectAPI.tunes_request_client.get(
          "v1/apps/#{app.id}/appPricePoints", { "filter[territory]" => "USA", "limit" => 10 }
        )
        free = pp_resp.body["data"].find { |p| p["attributes"]["customerPrice"].to_f == 0.0 }
        UI.user_error!("No FREE price point returned by ASC") unless free

        ::Spaceship::ConnectAPI.tunes_request_client.post(
          "v1/appPriceSchedules",
          {
            data: {
              type: "appPriceSchedules",
              relationships: {
                app:           { data: { type: "apps",        id: app.id } },
                baseTerritory: { data: { type: "territories", id: "USA"   } },
                manualPrices:  { data: [{ type: "appPrices",  id: "${price1}" }] }
              }
            },
            included: [{
              id: "${price1}", type: "appPrices",
              attributes: { startDate: nil },
              relationships: { appPricePoint: { data: { type: "appPricePoints", id: free["id"] } } }
            }]
          }
        )
        UI.success("Price set to Free")
      end
    end
  end

  desc "Print current categories; set primary to DEVELOPER_TOOLS if unset."
  lane :ensure_category do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        info = app.fetch_edit_app_info
        UI.user_error!("No editable app info") unless info
        current = ::Spaceship::ConnectAPI.tunes_request_client.get(
          "v1/appInfos/#{info.id}", { "include" => "primaryCategory,secondaryCategory" }
        )
        primary = current.body.dig("data", "relationships", "primaryCategory", "data", "id")
        UI.message("primary category currently: #{primary.inspect}")
        if primary.to_s.empty?
          info.update_categories(category_id_map: { primary_category_id: "DEVELOPER_TOOLS" })
          UI.success("Primary category set to DEVELOPER_TOOLS")
        else
          UI.success("Primary category already set — leaving as-is")
        end
      end
    end
  end

  desc "Patch the edit version: usesIdfa=false and releaseType=MANUAL. " \
       "deliver's submission_information does NOT set the version's usesIdfa " \
       "attribute, and MANUAL guarantees approval never auto-ships."
  lane :prepare_version_attrs do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        version = app.get_edit_app_store_version
        UI.user_error!("No editable version to patch") unless version
        ::Spaceship::ConnectAPI.tunes_request_client.patch(
          "v1/appStoreVersions/#{version.id}",
          { data: { type: "appStoreVersions", id: version.id,
                    attributes: { usesIdfa: false, releaseType: "MANUAL" } } }
        )
        UI.success("version #{version.id}: usesIdfa=false, releaseType=MANUAL")
      end
    end
  end

  desc "Set the full age-rating declaration (everything NONE/false — Pharos is " \
       "a single-user developer tool; its chat is with the owner's own agents, " \
       "not user-to-user). PATCHes at the appInfo level: the version-level path " \
       "errors, and fastlane 2.232's rating_config.json predates the 2025 " \
       "socialMedia fields."
  lane :set_age_rating do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        info   = app.fetch_edit_app_info
        client = ::Spaceship::ConnectAPI.tunes_request_client
        decl = client.get("v1/appInfos/#{info.id}/ageRatingDeclaration").body["data"]
        attributes = {
          advertising: false,
          ageAssurance: false,
          alcoholTobaccoOrDrugUseOrReferences: "NONE",
          contests: "NONE",
          gamblingSimulated: "NONE",
          gunsOrOtherWeapons: "NONE",
          healthOrWellnessTopics: false,
          horrorOrFearThemes: "NONE",
          lootBox: false,
          matureOrSuggestiveThemes: "NONE",
          medicalOrTreatmentInformation: "NONE",
          messagingAndChat: false,
          parentalControls: false,
          profanityOrCrudeHumor: "NONE",
          sexualContentGraphicAndNudity: "NONE",
          sexualContentOrNudity: "NONE",
          userGeneratedContent: false,
          violenceCartoonOrFantasy: "NONE",
          violenceRealistic: "NONE",
          violenceRealisticProlongedGraphicOrSadistic: "NONE",
          gambling: false,
          unrestrictedWebAccess: false,
          socialMedia: false,
          socialMediaAgeRestricted: false,
          kidsAgeBand: nil
        }
        client.patch("v1/ageRatingDeclarations/#{decl['id']}",
          { data: { type: "ageRatingDeclarations", id: decl["id"], attributes: attributes } })
        UI.success("Age rating declaration #{decl['id']} set (all NONE/false)")
      end
    end
  end

  desc "Attach the latest VALID processed build to the edit version. Pharos " \
       "uploads via beta, so fastlane#19633 (Xcode-Cloud builds only) doesn't apply."
  lane :select_build do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        version = app.get_edit_app_store_version
        UI.user_error!("No editable version") unless version
        client = ::Spaceship::ConnectAPI.tunes_request_client
        resp = client.get("v1/builds",
          { "filter[app]" => app.id, "sort" => "-uploadedDate", "limit" => 10 })
        build = resp.body["data"].find { |b| b["attributes"]["processingState"] == "VALID" }
        UI.user_error!("No VALID processed build to attach yet") unless build
        client.patch("v1/appStoreVersions/#{version.id}/relationships/build",
          { data: { type: "builds", id: build["id"] } })
        UI.success("Attached build #{build['attributes']['version']} (#{build['id']}) to version #{version.id}")
      end
    end
  end

  desc "Explain why the current version is not submittable — dumps the editable " \
       "version's state, review attributes, and attached build."
  lane :why_blocked do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        version = app.get_edit_app_store_version
        UI.user_error!("No editable version") unless version
        resp = ::Spaceship::ConnectAPI.tunes_request_client.get(
          "v1/appStoreVersions/#{version.id}",
          { "include" => "appStoreReviewDetail,appStoreVersionPhasedRelease,build" }
        )
        UI.message("state: #{resp.body['data']['attributes']['appStoreState']}")
        UI.message("attributes: #{resp.body['data']['attributes'].inspect}")
        resp.body["included"]&.each do |inc|
          UI.message("• #{inc['type']} #{inc['id']}: #{inc['attributes'].inspect}")
        end
      end
    end
  end

  desc "Submit the current version for review via the modern reviewSubmissions " \
       "flow (fastlane's submit_for_review posts to a removed endpoint). HUMAN " \
       "GATE: only run when the human explicitly says submit."
  lane :submit_review_v2 do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      with_spaceship(api_key) do |app|
        version = app.get_edit_app_store_version
        UI.user_error!("No editable version to submit") unless version
        client = ::Spaceship::ConnectAPI.tunes_request_client
        sub = client.post("v1/reviewSubmissions", {
          data: { type: "reviewSubmissions", attributes: { platform: "IOS" },
                  relationships: { app: { data: { type: "apps", id: app.id } } } }
        }).body["data"]["id"]
        client.post("v1/reviewSubmissionItems", {
          data: { type: "reviewSubmissionItems",
                  relationships: {
                    reviewSubmission: { data: { type: "reviewSubmissions", id: sub } },
                    appStoreVersion:  { data: { type: "appStoreVersions",  id: version.id } }
                  } }
        })
        client.patch("v1/reviewSubmissions/#{sub}", {
          data: { type: "reviewSubmissions", id: sub, attributes: { submitted: true } }
        })
        UI.success("Submitted for review (reviewSubmission #{sub}). Release is MANUAL.")
      end
    end
  end

  # ── App Store metadata staging (no review submission) ────────────────────────
  #
  # NOTE: Pharos is a PERSONAL tool. It talks to a Tailscale-bound mesh broker on
  # your own Mac, so a public App Review reviewer cannot exercise it without your
  # private tailnet + a running broker. The realistic distribution path is
  # TestFlight *internal* testing (your own Apple ID / devices), which needs no
  # review. `stage_listing`/`release` are kept for completeness; expect public
  # review to need a demo mode or an explicit reviewer note first.

  desc "Upload metadata to App Store Connect, leaving the listing in 'Prepare for " \
       "Submission' (no review submission). Personal app — see the note above."
  lane :stage_listing do
    api_key = asc_api_key
    with_env_unset("APP_STORE_CONNECT_API_KEY_PATH") do
      upload_to_app_store(
        api_key:            api_key,
        app_identifier:     APP_IDENTIFIER,
        app_version:        marketing_version,  # else deliver targets the LIVE version
        force:              true,
        submit_for_review:  false,
        skip_binary_upload: true,
        skip_screenshots:   false,
        overwrite_screenshots: true,
        precheck_include_in_app_purchases: false,
        app_review_information: {
          first_name:    "Xiang",
          last_name:     "Bai",
          phone_number:  ENV["ASC_REVIEW_PHONE"].to_s,
          email_address: ENV["ASC_REVIEW_EMAIL"] || "crea.bai@gmail.com",
          demo_user:     "",
          demo_password: "",
          notes:         <<~NOTE
            Pharos is a personal developer tool: an iPhone/iPad client for a
            self-hosted "mesh" chat/agent broker that runs on the owner's own Mac
            and is reachable only over a private Tailscale network. Without that
            private network + a running broker, the app has nothing to connect to,
            so it cannot be fully exercised by an external reviewer. It is
            distributed via TestFlight internal testing to the owner's own devices.
            Contact: #{ENV["ASC_REVIEW_EMAIL"] || "crea.bai@gmail.com"}
          NOTE
        }
      )
    end
  end

  desc "stage_listing + submit for review (personal app — usually not needed; " \
       "see the note above stage_listing)."
  lane :release do
    stage_listing
    UI.important("Public App Review may be infeasible for this app (private-network " \
                 "dependency). Submit from the ASC UI, or wire submit_review_v2 with a demo mode.")
  end
end
