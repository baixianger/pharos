# Copy to ios/.env and fill in. .env is gitignored; .env.example is committed.

# ── App Store Connect API key (.p8) ──────────────────────────────────────────
# Create at: App Store Connect → Users and Access → Integrations → App Store
# Connect API → generate a Team Key (role: App Manager or Admin). Download the
# .p8 ONCE and store it outside the repo.
APP_STORE_CONNECT_API_KEY_ID=ABCD1234
APP_STORE_CONNECT_API_ISSUER_ID=00000000-1111-2222-3333-444444444444
APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_ABCD1234.p8

# ── match (only for the TestFlight/App Store path; device_install doesn't need it) ─
# A PRIVATE git repo that stores the shared signing certs + profiles, and the
# password that encrypts them.
MATCH_GIT_URL=git@github.com:baixianger/certs.git
MATCH_PASSWORD=change-me-to-a-strong-random-password

# ── Optional ─────────────────────────────────────────────────────────────────
# Target a specific device for `device_install` (else the first paired device).
# DEVICE_UDID=00008140-000A4C422EB8801C

# Shown to App Review in stage_listing (personal app — usually TestFlight only).
# ASC_REVIEW_EMAIL=you@example.com
# ASC_REVIEW_PHONE=+1 555 5555
